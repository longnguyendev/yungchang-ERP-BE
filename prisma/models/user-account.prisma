model UserAccount {
  id         Int         @id @default(autoincrement())
  employeeId String      @unique
  employee   Employee    @relation(fields: [employeeId], references: [id])
  username   String      @unique
  email      String?     @unique
  password   String
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  tokens     UserToken[]
  verified   Boolean     @default(false)

  // Audit fields
  createdBy String?
  updatedBy String?

  // Audit relations to Employee
  createdByEmployee Employee? @relation("UACreatedBy", fields: [createdBy], references: [id])
  updatedByEmployee Employee? @relation("UAUpdatedBy", fields: [updatedBy], references: [id])
}
